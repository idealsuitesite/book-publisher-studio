{
  "name": "book-publisher-backend",
  "version": "1.0.0",
  "description": "Backend API for Book Publisher Studio",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write src",
    "verify-server": "tsx scripts/verify-server.ts",
    "verify-real-export": "tsx scripts/verify-real-export.ts"
  },
  "keywords": [],
  "author": "Alexandre",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "docx": "^9.7.1",
    "domhandler": "^6.0.1",
    "epub-gen-memory": "^1.1.2",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "multer": "^2.2.0",
    "pdfkit": "^0.19.1",
    "shared-types": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.10.6",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "jszip": "^3.10.1",
    "prettier": "^3.9.5",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
